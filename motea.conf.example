# motea 配置文件
# 将此文件复制为 motea.conf 并根据需要修改配置

# ===========================================
# 基本配置（必需）
# ===========================================

# 应用访问密码
PASSWORD=your_secure_password_here

# 预加载笔记数量（推荐：5-20，Vercel建议5-10）
PRELOAD_NOTES_COUNT=10

# ===========================================
# 可选配置
# ===========================================

# 禁用密码认证（仅开发环境使用）
# DISABLE_PASSWORD=true

# ===========================================
# 使用说明
# ===========================================
# 1. 复制此文件为 motea.conf
# 2. 修改 PASSWORD 为你的安全密码
# 3. 根据需要调整 PRELOAD_NOTES_COUNT
# 4. 重启容器使配置生效
#
# 注意：数据库连接在独立部署中自动配置，无需设置
